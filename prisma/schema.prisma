generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========== ENUMS ==========

enum Role {
  super_admin
  club_admin
  trainer
  member
  user
}

enum ClubStatus {
  active
  inactive
  closed
}

enum TariffType {
  single    // разовое посещение
  monthly   // месячный абонемент
  quarterly // квартальный
  yearly    // годовой
}

// ========== MODELS ==========

// 👤 Пользователи
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(user)

  balance     Balance?       // баланс пользователя
  transactions Transaction[] // история операций

  // 👇 Привязка к клубу (для club_admin, trainer, member)
  clubId    Int?     @map("club_id")
  club      Club?    @relation(fields: [clubId], references: [id])

  // 👇 Выбранный тариф (для member)
  tariffId  Int?     @map("tariff_id")
  tariff    Tariff?  @relation(fields: [tariffId], references: [id])

  // 👇 Данные участника (зависят от конкретной покупки)
  startDate DateTime? @map("start_date")
  endDate   DateTime? @map("end_date")
  paid      Boolean?  @default(false)
  paidAt    DateTime? @map("paid_at")

  // 👇 Данные сотрудника (для club_admin, trainer)
  position  String?
  hiredAt   DateTime? @map("hired_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

// 🏢 Клубы
model Club {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  address   String
  phone     String?
  email     String?
  description String?
  logo      String?
  status    ClubStatus   @default(active)
  workingHours Json?

  // Связи
  users     User[]
  tariffs   Tariff[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("clubs")
}

// 💰 Тарифы (привязаны к клубу)
model Tariff {
  id        Int      @id @default(autoincrement())
  clubId    Int      @map("club_id")
  club      Club     @relation(fields: [clubId], references: [id])

  name      String        // например: "Месячный безлимит"
  type      TariffType
  price     Float
  duration  Int?          // длительность в днях (null для single)
  isActive  Boolean  @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Пользователи, купившие этот тариф
  users     User[]

  @@unique([clubId, name]) // в одном клубе тарифы с уникальными названиями
  @@map("tariffs")
}

// Баланс пользователя (один к одному с User)
model Balance {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique @map("user_id")
  user      User     @relation(fields: [userId], references: [id])

  amount    Float    @default(100)      // текущий баланс
  currency  String   @default("BYN")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("balances")
}

// История транзакций
model Transaction {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id])

  type      TransactionType
  amount    Float
  balanceAfter Float @map("balance_after")

  // Для привязки к конкретной покупке
  tariffId  Int? @map("tariff_id")
  clubId    Int? @map("club_id")

  description String?  // комментарий (например: "Оплата тарифа Месячный")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("transactions")
}

enum TransactionType {
  deposit          // пополнение
  payment          // успешная оплата
  failed_payment   // неудачная попытка оплаты
  refund           // возврат
}